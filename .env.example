# --- LLM ---
OPENAI_API_KEY= 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
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=260
LLM_TEMPERATURE=0.2

# Optional OpenAI-compatible endpoint (for GitHub Models etc.)
OPENAI_BASE_URL=
GITHUB_TOKEN=
GITHUB_API_VERSION=2022-11-28
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference

# --- Embeddings ---
EMBEDDING_PROVIDER=sentence_transformers
ST_MODEL=BAAI/bge-m3
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Paths ---
KB_PATH=knowledge_base
CHROMA_PATH=knowledge_base/vector_store_chroma
COLLECTION_NAME=kb_main
APPOINTMENTS_PATH=data/appointments.json

# --- Retrieval / Guardrails ---
TOP_K=6
RETRIEVE_TOP_N=10
MIN_SIMILARITY=0.35
MIN_KEYWORD_OVERLAP=0.15
HIGH_SIMILARITY_OVERRIDE=0.65
CLARIFY_MIN_SIMILARITY=0.25
MAX_CONTEXT_CHARS=8000
USE_RERANKER=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_KEEP_K=3
RERANK_MAX_DOC_CHARS=900
RERANK_DEVICE=cuda

# --- Agentic ---
USE_LANGGRAPH=true

# --- App ---
HOST=0.0.0.0
PORT=8000

# --- LangSmith tracing (optional but recommended for demos) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=civicflow_agent_demo
LANGSMITH_API_KEY=
